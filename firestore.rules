rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ─── Helper functions ───
    function isSignedIn() { return request.auth != null; }
    function isMe(uid) { return isSignedIn() && request.auth.uid == uid; }
    function ownsExisting(field) { return isSignedIn() && resource.data[field] == request.auth.uid; }
    function affected() { return request.resource.data.diff(resource.data).affectedKeys(); }
    function counterOnlyChange(allowed) { return affected().hasOnly(allowed); }
    // Allow only ±1 delta on counter fields. If field wasn't touched, OK; if touched, delta must be ±1.
    function deltaOk(field) {
      return !(field in affected())
        || request.resource.data[field] == resource.data[field] + 1
        || request.resource.data[field] == resource.data[field] - 1;
    }
    function roomData(roomId) {
      return get(/databases/$(database)/documents/chatRooms/$(roomId)).data;
    }
    function isRoomMember(roomId) {
      return isSignedIn() && request.auth.uid in roomData(roomId).members;
    }
    function isOpenRoom(roomId) {
      return roomData(roomId).type == 'open';
    }

    // ─── Public-readable collections (guests included) ───
    match /users/{userId} { allow read: if true; }
    match /categories/{categoryId} { allow read: if true; }
    match /hashtags/{tag} { allow read: if true; }

    // ─── Admin-only verification code stores ───
    match /emailChangeCodes/{uid}    { allow read, write: if false; }
    match /passwordResetCodes/{uid}  { allow read, write: if false; }
    match /phoneAuthCodes/{id}       { allow read, write: if false; }
    match /signupCodes/{id}          { allow read, write: if false; }
    match /rateLimits/{id}           { allow read, write: if false; }

    // Per-user private data (email, etc.) — owner only
    match /userPrivate/{userId} {
      allow read, write: if isMe(userId);
    }

    // ─── Users ───
    match /users/{userId} {
      allow create: if isMe(userId);
      allow delete: if isMe(userId);
      allow update: if isMe(userId)
        || (isSignedIn()
            && counterOnlyChange(['followersCount', 'followingCount', 'tweetsCount'])
            && deltaOk('followersCount')
            && deltaOk('followingCount')
            && deltaOk('tweetsCount'));
    }

    // ─── Tweets ───
    match /tweets/{tweetId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.authorUid == request.auth.uid;
      allow delete: if ownsExisting('authorUid');
      allow update: if ownsExisting('authorUid')
        || (isSignedIn()
            && counterOnlyChange(['likesCount', 'bookmarksCount', 'repliesCount', 'viewsCount'])
            && deltaOk('likesCount')
            && deltaOk('bookmarksCount')
            && deltaOk('repliesCount')
            && deltaOk('viewsCount'));
    }

    // ─── Threads ───
    match /threads/{threadId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.authorUid == request.auth.uid;
      allow delete: if ownsExisting('authorUid');
      allow update: if ownsExisting('authorUid')
        || (isSignedIn()
            && counterOnlyChange(['repliesCount', 'lastReplyAt', 'likesCount'])
            && deltaOk('repliesCount')
            && deltaOk('likesCount'));

      match /replies/{replyId} {
        allow read: if true;
        allow create: if isSignedIn() && request.resource.data.authorUid == request.auth.uid;
        allow update, delete: if ownsExisting('authorUid');
      }
    }

    // ─── Chat rooms ───
    match /chatRooms/{roomId} {
      // Open chats are public-readable; DM/group strictly members-only
      allow read: if resource.data.type == 'open'
        || (isSignedIn() && request.auth.uid in resource.data.members);

      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.auth.uid in request.resource.data.members;

      // Critical fields are immutable. Members can update; non-members can join open chats by adding self.
      allow update: if isSignedIn()
        && request.resource.data.type == resource.data.type
        && request.resource.data.createdBy == resource.data.createdBy
        && (
          request.auth.uid in resource.data.members
          || (
            resource.data.type == 'open'
            && request.auth.uid in request.resource.data.members
            && request.resource.data.members.hasAll(resource.data.members)
          )
        );

      allow delete: if ownsExisting('createdBy');

      match /messages/{messageId} {
        allow read: if isOpenRoom(roomId)
          || (isSignedIn() && request.auth.uid in roomData(roomId).members);
        allow create: if isSignedIn()
          && request.resource.data.senderUid == request.auth.uid
          && (isOpenRoom(roomId) || request.auth.uid in roomData(roomId).members);
        // Allow only readBy additions (mark-as-read), preserving existing entries.
        allow update: if isSignedIn()
          && affected().hasOnly(['readBy'])
          && request.resource.data.readBy.hasAll(resource.data.readBy)
          && request.auth.uid in request.resource.data.readBy;
      }

      match /notes/{noteId} {
        allow read: if isRoomMember(roomId);
        allow create: if isSignedIn()
          && request.resource.data.authorUid == request.auth.uid
          && isRoomMember(roomId);
        allow delete: if ownsExisting('authorUid');
      }

      match /events/{eventId} {
        allow read: if isRoomMember(roomId);
        allow create: if isSignedIn()
          && request.resource.data.authorUid == request.auth.uid
          && isRoomMember(roomId);
        allow update: if ownsExisting('authorUid');
        allow delete: if ownsExisting('authorUid');
      }

      match /files/{fileId} {
        allow read: if isRoomMember(roomId);
        allow create: if isSignedIn()
          && request.resource.data.uploaderUid == request.auth.uid
          && isRoomMember(roomId);
        allow delete: if ownsExisting('uploaderUid');
      }
    }

    // ─── Chat notification preferences (id format: `${uid}_${roomId}`) ───
    match /chatNotificationPrefs/{prefId} {
      allow read, write: if isSignedIn()
        && prefId.matches(request.auth.uid + '_.*');
    }

    // ─── Polls ───
    match /polls/{pollId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.createdByUid == request.auth.uid;
      allow update: if (isSignedIn() && resource.data.createdByUid == request.auth.uid)
        || (isSignedIn() && counterOnlyChange(['voters', 'votes']));
    }

    // ─── Follows ───
    match /follows/{followId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.followerUid == request.auth.uid
        && followId == request.auth.uid + '_' + request.resource.data.followingUid;
      allow delete: if isSignedIn()
        && (resource.data.followerUid == request.auth.uid
            || resource.data.followingUid == request.auth.uid);
    }

    // ─── Follow requests ───
    match /followRequests/{requestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.fromUid == request.auth.uid
        && requestId == request.auth.uid + '_' + request.resource.data.toUid;
      allow delete: if isSignedIn()
        && (resource.data.fromUid == request.auth.uid
            || resource.data.toUid == request.auth.uid);
    }

    // ─── Likes ───
    match /likes/{likeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && likeId == request.auth.uid + '_' + request.resource.data.tweetId;
      allow delete: if ownsExisting('userId');
    }

    // ─── Thread likes ───
    match /threadLikes/{likeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && likeId == request.auth.uid + '_' + request.resource.data.threadId;
      allow delete: if ownsExisting('userId');
    }

    // ─── Bookmarks ───
    match /bookmarks/{bookmarkId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && bookmarkId == request.auth.uid + '_' + request.resource.data.tweetId;
      allow delete: if ownsExisting('userId');
    }

    // ─── Notifications ───
    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.actorUid == request.auth.uid;
      allow update: if isSignedIn() && resource.data.recipientUid == request.auth.uid;
    }

    // ─── Categories ───
    match /categories/{categoryId} {
      allow create: if isSignedIn()
        && (request.resource.data.createdBy == request.auth.uid
            || request.resource.data.type == 'default');
      allow update: if (isSignedIn() && resource.data.createdBy == request.auth.uid)
        || (isSignedIn() && counterOnlyChange(['membersCount']) && deltaOk('membersCount'));

      match /members/{memberId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && request.resource.data.userId == request.auth.uid
          && memberId == request.auth.uid;
        allow delete: if ownsExisting('userId');
      }
    }

    // ─── Tweet views ───
    match /tweetViews/{viewId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
    }

    // ─── Reports ───
    match /reports/{reportId} {
      allow read: if isSignedIn() && resource.data.reporterUid == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.reporterUid == request.auth.uid;
    }

    // ─── Shorts ───
    match /shorts/{shortId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.authorUid == request.auth.uid;
      allow delete: if ownsExisting('authorUid');
      allow update: if ownsExisting('authorUid')
        || (isSignedIn()
            && counterOnlyChange(['likesCount', 'bookmarksCount', 'commentsCount', 'viewsCount'])
            && deltaOk('likesCount')
            && deltaOk('bookmarksCount')
            && deltaOk('commentsCount')
            && deltaOk('viewsCount'));
    }
  }
}
